@page "/"
@using System.Diagnostics
@using System.Runtime.InteropServices.JavaScript
@using Microsoft.Extensions.Logging
@inject IJSRuntime JsRuntime
@inject ILogger<Home> Logger
@implements IDisposable

<div class="kt-container-fluid">
    <div class="flex flex-col">
        <div class="kt-card">
            <div class="kt-card-header">
                <h3 class="kt-card-title">System Information</h3>
            </div>
            <div class="kt-card-content flex flex-row justify-start items-stretch grow px-3 py-1 gap-10">
                <div class="flex flex-col justify-center items-center w-[150px] my-2">
                    <h2 class="text-gray-500 text-[16px]">CPU Usage</h2>
                    <div id="chartCPU" style="min-height: 160px;" data-total="0"></div>
                    <span class="text-gray-500 text-[14px]">@(Environment.ProcessorCount) Cores</span>
                </div>
                <div class="flex flex-col justify-center items-center w-[150px] my-2">
                    <h2 class="text-gray-500 text-[16px]">RAM Usage</h2>
                    <div id="chartRAM" style="min-height: 160px;" data-total="0"></div>
                    <span class="text-gray-500 text-[14px]">@_ramTotal GB</span>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="/assets/js/custom/home.js"></script>
@code {
    private const int UpdateInterval = 3000;
    private readonly List<PerformanceCounter> _cpuCounters = new();
    private PerformanceCounter _ramCounter = new();

    private double _ramTotal;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            InitializeCounters();
            await WarmUpCountersAsync();
            await InitializeChartsAsync();
            
            _timer = new Timer(_ => InvokeAsync(UpdateSystemInfo), null, UpdateInterval, UpdateInterval);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing system information");
        }
    }

    private void InitializeCounters()
    {
        // Initialize CPU counters
        for (int i = 0; i < Environment.ProcessorCount; i++)
        {
            var counter = new PerformanceCounter("Processor", "% Processor Time", i.ToString());
            _cpuCounters.Add(counter);
            counter.NextValue();
        }
        
        // Add total counter
        var totalCounter = new PerformanceCounter("Processor", "% Processor Time", "_Total");
        _cpuCounters.Add(totalCounter);
        totalCounter.NextValue();

        // Initialize RAM counter
        _ramCounter = new PerformanceCounter("Memory", "% Committed Bytes In Use");
        _ramCounter.NextValue();
        
        // Calculate total RAM in GB
        _ramTotal = GetTotalPhysicalMemory();
        
        // Add disk space counter by label
        
    }

    private async Task WarmUpCountersAsync()
    {
        await Task.Delay(1000); // First value is usually 0
    }

    private async Task InitializeChartsAsync()
    {
        await JsRuntime.InvokeVoidAsync("initializeCharts");
    }

    private void UpdateSystemInfo()
    {
        try
        {
            int cpuUsage = GetCpuUsage();
            int ramUsage = GetRamUsage();
            
            JsRuntime.InvokeVoidAsync("updateCharts", cpuUsage, ramUsage);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating system information");
        }
    }

    private int GetCpuUsage()
    {
        return (int)_cpuCounters
            .Where(c => c.InstanceName == "_Total")
            .Select(c => c.NextValue())
            .FirstOrDefault();
    }

    private int GetRamUsage()
    {
        return (int)Math.Round(_ramCounter.NextValue());
    }
    
    private double GetTotalPhysicalMemory()
    {
        try
        {
            using var searcher = new ManagementObjectSearcher("SELECT TotalPhysicalMemory FROM Win32_ComputerSystem");
            foreach (var item in searcher.Get())
            {
                var ramInString = item["TotalPhysicalMemory"]?.ToString();
                if (ulong.TryParse(ramInString, out var totalMemory))
                {
                    double result = totalMemory * 1.0 / (1024 * 1024 * 1024); // Chuyển sang GB
                    return Math.Round(result, 2);
                }
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine("Không thể lấy tổng RAM vật lý: " + ex.Message);
        }

        return 0;
    }

    public void Dispose()
    {
        _timer?.Dispose();
        
        foreach (var counter in _cpuCounters)
        {
            counter.Dispose();
        }
        
        _ramCounter.Dispose();
    }
}